# SMC Performance Tracker - Environment Variables
# Copy to .env or set in Railway dashboard

# REQUIRED: Your API key for webhook authentication
SMC_API_KEY=your-api-key-here

# Server settings (Railway sets PORT automatically)
PORT=5000
HOST=0.0.0.0

# Auth
REQUIRE_AUTH=true

# Logging
LOG_LEVEL=INFO

# Price Tracker (optional)
PRICE_TRACKER_ENABLED=false
PRICE_PROVIDER=mock
PRICE_API_KEY=

# Database (Railway uses ephemeral storage; SQLite is fine for personal use)
DATABASE_PATH=data/smc_tracker.db
