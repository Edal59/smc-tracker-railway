{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm start",
    "restartPolicyMaxRetries": 5
  },
  "plugins": [],
  "variables": {
    "PORT": {
      "description": "Port to run the application on",
      "value": "3000"
    },
    "NODE_ENV": {
      "description": "Environment type",
      "value": "production"
    }
  }
}
