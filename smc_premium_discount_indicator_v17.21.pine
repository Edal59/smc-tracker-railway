// =========================================================================
// v17.13: ALERT SYSTEM CONFIGURATION
// =========================================================================
grpAlertSystem = "═══ ALERT SYSTEM CONFIGURATION ═══"
confluence_threshold_sniper   = input.int(4, "Sniper Confluence Threshold", minval=0, maxval=8, group=grpAlertSystem, tooltip="Minimum confluence score required for Sniper alerts to fire.")
